# Core
SQLITE_DB_PATH=database/insurevn.db

# Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_HOST=http://localhost:3000

# --- Standard Provider Globals ---
# These are shared across all agents and scripts.
# You can provide a single key or a comma-separated list.
# You can also use numbered variables like GOOGLE_API_KEY_1, GOOGLE_API_KEY_2, etc.

GOOGLE_API_KEY=
# GOOGLE_API_KEY_1=
# GOOGLE_API_KEY_2=
OPENROUTER_API_KEY=
# OPENROUTER_API_KEY_1=

NVIDIA_API_KEY=
# NVIDIA_API_KEY_1=

OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_BASE_URLS=http://localhost:11434,http://another:11434
QWEN_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

JINA_API_KEY=
TAVILY_API_KEY=

# Global LLM defaults (Optional, used as fallback if component settings are missing)
# LLM_PROVIDER=OLLAMA
# LLM_MODEL=OLLAMA_LLM_MODEL
# LLM_API_KEY=
# LLM_BASE_URL=

# --- Agent/Component Overrides ---
# These agents now support explicit configuration with prefixes (SQL_AGENT, SEARCH_AGENT).
# They also support indirect model resolution (e.g., tring a MODEL to an ENV variable name).

# Database Agent (SQL Agent)
SQL_AGENT_PROVIDER=OLLAMA
SQL_AGENT_MODEL=OLLAMA_LLM_MODEL
SQL_AGENT_API_KEY=Ollama_API_Key_1
# SQL_AGENT_BASE_URL=
DATABASE_LLM_TEMPERATURE=1.0

# Search Agent
SEARCH_AGENT_PROVIDER=NVIDIA
SEARCH_AGENT_MODEL=NVIDIA_LLM_MODEL
SEARCH_AGENT_API_KEY=NVIDIA_API_KEY
# SEARCH_AGENT_BASE_URL=
SEARCH_LLM_TEMPERATURE=0.7
SEARCH_MAX_RESULTS=50

# RAG/Qdrant
RAG_QDRANT_URL=http://localhost:6333
RAG_QDRANT_API_KEY=
RAG_QDRANT_COLLECTION=insurevn_policy_chunks
RAG_DENSE_VECTOR_NAME=text_dense
RAG_SPARSE_VECTOR_NAME=text_sparse
RAG_EMBEDDING_PROVIDER=HUGGINGFACE
RAG_EMBEDDING_MODEL=QWEN_EMBEDDING_MODEL
RAG_EMBEDDING_API_KEY=
RAG_DENSE_VECTOR_SIZE=4096
RAG_EMBEDDING_BATCH_SIZE=4
RAG_EMBEDDING_MAX_LENGTH=8192
RAG_EMBEDDING_LOAD_IN_4BIT=true
RAG_EMBEDDING_DEVICE_MAP=auto
# Leave empty unless flash-attn is installed and verified locally.
RAG_EMBEDDING_ATTN_IMPLEMENTATION=
RAG_EMBEDDING_QUERY_TASK_DESCRIPTION=Given a web search query, retrieve relevant passages that answer the query
RAG_SPARSE_MODEL=Qdrant/bm25
RAG_VIETNAMESE_SEGMENTER=underthesea

# Chunking logic
RAG_CHUNKING_STRATEGY=hierarchical_header_recursive

# Knowledge Graph / Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
GRAPH_JSON_PATH=data/processed/knowledge_graph/insurevn_graph.json
GRAPH_MAX_HOPS=2

# Knowledge Graph Extraction/QA
KG_EXTRACTION_LLM_PROVIDER=OLLAMA
KG_EXTRACTION_LLM_MODEL=OLLAMA_LLM_MODEL
KG_EXTRACTION_LLM_API_KEY=Ollama_API_Key_1
KG_EXTRACTION_LLM_BASE_URL=OLLAMA_BASE_URL
KG_EXTRACTION_LLM_TEMPERATURE=0.0
KG_CYPHER_QA_LLM_PROVIDER=OLLAMA
KG_CYPHER_QA_LLM_MODEL=OLLAMA_LLM_MODEL
KG_CYPHER_QA_LLM_API_KEY=Ollama_API_Key_1
KG_CYPHER_QA_LLM_BASE_URL=OLLAMA_BASE_URL
KG_CYPHER_QA_LLM_TEMPERATURE=0.0

# Knowledge Graph Schema Discovery
# KG_SCHEMA_DISCOVERY_MAX_CONCURRENCY=20
# KG_SCHEMA_DISCOVERY_CHUNK_CHARS=12000
# KG_SCHEMA_DISCOVERY_OUTPUT_DIR=data/processed/knowledge_graph/schema_discovery

# Optional Tools
FIRECRAWL_API_KEY=
DATALAB_KEY=
