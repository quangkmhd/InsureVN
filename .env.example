# RAG/Qdrant Document Retrieval
RAG_QDRANT_URL=http://localhost:6333
RAG_QDRANT_API_KEY=
RAG_QDRANT_COLLECTION=insurevn_policy_chunks
RAG_DENSE_VECTOR_NAME=text_dense
RAG_SPARSE_VECTOR_NAME=text_sparse
RAG_EMBEDDING_PROVIDER=google_genai
RAG_EMBEDDING_MODEL=gemini-embedding-2-preview
RAG_SPARSE_MODEL=Qdrant/bm25
RAG_VIETNAMESE_SEGMENTER=underthesea
RAG_CHILD_CHUNK_TOKENS=1200
RAG_CHILD_CHUNK_OVERLAP=150
RAG_PARENT_SECTION_MAX_CHARS=6000
RAG_RETRIEVAL_TOP_K=5
RAG_RETRIEVAL_TIMEOUT_SECONDS=30.0
RAG_REQUIRE_HYBRID_SEARCH=true
RAG_ALLOW_DENSE_ONLY_DEGRADED_MODE=false
GOOGLE_API_KEY=

# Knowledge Graph / Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
GRAPH_JSON_PATH=data/processed/knowledge_graph/insurevn_graph.json
GRAPH_MAX_HOPS=2
GRAPH_RELOAD_ON_STARTUP=true
GRAPH_EAGER_K=5
GRAPH_EAGER_START_K=1
GRAPH_EAGER_MAX_DEPTH=2
GRAPH_MIN_CONFIDENCE=0.75
