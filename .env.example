# Core
SQLITE_DB_PATH=database/insurevn.db

# Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_HOST=http://localhost:3000

# Global LLM defaults
LLM_PROVIDER=ollama
LLM_MODEL=gemma4:31b-cloud
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434

# Database agent LLM
DATABASE_LLM_PROVIDER=ollama
DATABASE_LLM_MODEL=gemma4:31b-cloud
DATABASE_LLM_API_KEY=
DATABASE_LLM_BASE_URL=http://localhost:11434
DATABASE_LLM_TEMPERATURE=1.0
DATABASE_LLM_TOP_P=0.95
DATABASE_LLM_TOP_K=64

# Search agent
SEARCH_TAVILY_API_KEY=
SEARCH_MAX_RESULTS=50
SEARCH_LLM_PROVIDER=ollama
SEARCH_LLM_MODEL=gemma4:31b-cloud
SEARCH_LLM_API_KEY=
SEARCH_LLM_BASE_URL=http://localhost:11434
SEARCH_LLM_TEMPERATURE=0.7
SEARCH_LLM_TOP_P=0.95
SEARCH_LLM_TOP_K=64

# RAG/Qdrant document retrieval
RAG_QDRANT_URL=http://localhost:6333
RAG_QDRANT_API_KEY=
RAG_QDRANT_COLLECTION=insurevn_policy_chunks
RAG_DENSE_VECTOR_NAME=text_dense
RAG_SPARSE_VECTOR_NAME=text_sparse
RAG_EMBEDDING_PROVIDER=google_genai
RAG_EMBEDDING_MODEL=gemini-embedding-2-preview
RAG_SPARSE_MODEL=Qdrant/bm25
RAG_VIETNAMESE_SEGMENTER=underthesea
RAG_CHILD_CHUNK_TOKENS=1200
RAG_CHILD_CHUNK_OVERLAP=150
RAG_PARENT_SECTION_MAX_CHARS=6000
RAG_RETRIEVAL_TOP_K=5
RAG_RETRIEVAL_TIMEOUT_SECONDS=30.0
RAG_REQUIRE_HYBRID_SEARCH=true
RAG_ALLOW_DENSE_ONLY_DEGRADED_MODE=false
GOOGLE_API_KEY=

# Knowledge graph / Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
GRAPH_JSON_PATH=data/processed/knowledge_graph/insurevn_graph.json
GRAPH_MAX_HOPS=2
GRAPH_RELOAD_ON_STARTUP=true
GRAPH_EAGER_K=5
GRAPH_EAGER_START_K=1
GRAPH_EAGER_MAX_DEPTH=2
GRAPH_MIN_CONFIDENCE=0.75

# Optional data acquisition and conversion scripts
FIRECRAWL_API_KEY=
DATALAB_KEY=
DATALAB_KEY_1=
DATALAB_KEY_2=
DATALAB_KEY_3=
GEMINI_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
NVIDIA_API_KEY=
NVIDIA_PAI_KEY_1=
OPENROUTER_API_KEY=
