# Core
SQLITE_DB_PATH=database/insurevn.db

# Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_HOST=http://localhost:3000

# Global LLM defaults
LLM_PROVIDER=ollama
LLM_MODEL=gemma4:31b-cloud
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434

# Chunking comparison LLM
LLM_CHUNKING_PROVIDER=google_genai
LLM_CHUNKING_MODEL=gemma-4-31b-it
LLM_CHUNKING_MAX_INPUT_CHARS=50000
LLM_CHUNKING_TIMEOUT_SECONDS=120
LLM_CHUNKING_CACHE_PATH=reports/chunking_compare_llm/llm_chunk_cache.json
LLM_CHUNKING_UNIT_PREVIEW_CHARS=220

# Database agent LLM
DATABASE_LLM_PROVIDER=ollama
DATABASE_LLM_MODEL=gemma4:31b-cloud
DATABASE_LLM_API_KEY=
DATABASE_LLM_BASE_URL=http://localhost:11434
DATABASE_LLM_TEMPERATURE=1.0
DATABASE_LLM_TOP_P=0.95
DATABASE_LLM_TOP_K=64

# Search agent
SEARCH_TAVILY_API_KEY=
SEARCH_MAX_RESULTS=50
SEARCH_LLM_PROVIDER=ollama
SEARCH_LLM_MODEL=gemma4:31b-cloud
SEARCH_LLM_API_KEY=
SEARCH_LLM_BASE_URL=http://localhost:11434
SEARCH_LLM_TEMPERATURE=0.7
SEARCH_LLM_TOP_P=0.95
SEARCH_LLM_TOP_K=64

# RAG/Qdrant document retrieval
RAG_QDRANT_URL=http://localhost:6333
RAG_QDRANT_API_KEY=
RAG_QDRANT_COLLECTION=insurevn_policy_chunks
RAG_DENSE_VECTOR_NAME=text_dense
RAG_SPARSE_VECTOR_NAME=text_sparse
RAG_EMBEDDING_PROVIDER=google_genai
RAG_EMBEDDING_MODEL=gemini-embedding-2
RAG_DENSE_VECTOR_SIZE=768
RAG_SPARSE_MODEL=Qdrant/bm25
RAG_VIETNAMESE_SEGMENTER=underthesea
RAG_CHILD_CHUNK_MAX_CHARS=1200
RAG_CHILD_CHUNK_OVERLAP=150
RAG_CHUNKING_STRATEGY=hybrid_semantic
RAG_SEMANTIC_TARGET_CHARS=1400
RAG_SEMANTIC_MAX_CHARS=3500
RAG_SEMANTIC_MIN_CHARS=350
RAG_SEMANTIC_BREAKPOINT_TYPE=interquartile
RAG_SEMANTIC_BREAKPOINT_AMOUNT=1.5
SEMANTIC_CHUNKING_EMBEDDING_PROVIDER=ollama
SEMANTIC_CHUNKING_EMBEDDING_MODEL=qwen3-embedding:8b
SEMANTIC_CHUNKING_OLLAMA_BASE_URL=http://127.0.0.1:11434
RAG_TABLE_LINE_RATIO_THRESHOLD=0.55
RAG_TABLE_CHUNK_MAX_CHARS=3500
RAG_PARENT_SECTION_MAX_CHARS=6000
RAG_RETRIEVAL_TOP_K=5
RAG_RETRIEVAL_TIMEOUT_SECONDS=30.0
JINA_API_KEY=
RAG_RERANK_PROVIDER=jina
RAG_RERANK_MODEL=jina-reranker-v3
RAG_RERANK_BASE_URL=https://api.jina.ai/v1/rerank
RAG_RERANK_TIMEOUT_SECONDS=30.0
RAG_REQUIRE_HYBRID_SEARCH=true
RAG_ALLOW_DENSE_ONLY_DEGRADED_MODE=false
GOOGLE_API_KEY=

# Knowledge graph / Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
GRAPH_JSON_PATH=data/processed/knowledge_graph/insurevn_graph.json
GRAPH_MAX_HOPS=2
GRAPH_RELOAD_ON_STARTUP=true
GRAPH_EAGER_K=5
GRAPH_EAGER_START_K=1
GRAPH_EAGER_MAX_DEPTH=2
GRAPH_MIN_CONFIDENCE=0.75

# Knowledge graph schema discovery
KG_SCHEMA_DISCOVERY_OLLAMA_API_KEYS=
KG_SCHEMA_DISCOVERY_OLLAMA_BASE_URL=http://localhost:11434
KG_SCHEMA_DISCOVERY_OLLAMA_MODEL=gemma4:31b-cloud
KG_SCHEMA_DISCOVERY_OPENROUTER_API_KEYS=
KG_SCHEMA_DISCOVERY_OPENROUTER_MODEL=
KG_SCHEMA_DISCOVERY_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
KG_SCHEMA_DISCOVERY_NVIDIA_API_KEYS=
KG_SCHEMA_DISCOVERY_NVIDIA_MODEL=
KG_SCHEMA_DISCOVERY_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
KG_SCHEMA_DISCOVERY_GEMINI_API_KEYS=
KG_SCHEMA_DISCOVERY_GEMINI_MODEL=gemini-2.5-flash
KG_SCHEMA_DISCOVERY_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
KG_SCHEMA_DISCOVERY_MAX_CONCURRENCY=20
KG_SCHEMA_DISCOVERY_CHUNK_CHARS=12000
KG_SCHEMA_DISCOVERY_CHUNK_OVERLAP=500
KG_SCHEMA_DISCOVERY_ATTEMPT_TIMEOUT_SECONDS=90.0
KG_SCHEMA_DISCOVERY_OUTPUT_DIR=data/processed/knowledge_graph/schema_discovery

# Optional data acquisition and conversion scripts
FIRECRAWL_API_KEY=
DATALAB_KEY=
DATALAB_KEY_1=
DATALAB_KEY_2=
DATALAB_KEY_3=
GEMINI_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
NVIDIA_API_KEY=
NVIDIA_PAI_KEY_1=
OPENROUTER_API_KEY=
