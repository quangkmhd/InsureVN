# Core
SQLITE_DB_PATH=database/insurevn.db

# Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000
LANGFUSE_HOST=http://localhost:3000

# --- Standard Provider Globals ---
# These are shared across all agents and scripts.
# You can provide a single key or a comma-separated list.
# You can also use numbered variables like GOOGLE_API_KEY_1, GOOGLE_API_KEY_2, etc.

GOOGLE_API_KEY=
# GOOGLE_API_KEY_1=
# GOOGLE_API_KEY_2=

OPENROUTER_API_KEY=
# OPENROUTER_API_KEY_1=

NVIDIA_API_KEY=
# NVIDIA_API_KEY_1=

OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_BASE_URLS=http://localhost:11434,http://another:11434

JINA_API_KEY=
TAVILY_API_KEY=

# Global LLM defaults
# Agents will use these unless explicitly overridden.
LLM_PROVIDER=ollama
LLM_MODEL=gemma4:31b-cloud
# LLM_API_KEY=
# LLM_BASE_URL=

# --- Agent/Component Overrides ---
# Use these ONLY if you want a specific agent to use a different provider/model.
# If omitted, they fall back to global LLM defaults and then Provider Globals.

# Database Agent
# DATABASE_LLM_PROVIDER=
# DATABASE_LLM_MODEL=
# DATABASE_LLM_API_KEY=
DATABASE_LLM_TEMPERATURE=1.0

# Search Agent
# SEARCH_LLM_PROVIDER=
# SEARCH_LLM_MODEL=
SEARCH_LLM_TEMPERATURE=0.7
SEARCH_MAX_RESULTS=50

# RAG/Qdrant
RAG_QDRANT_URL=http://localhost:6333
RAG_QDRANT_API_KEY=
RAG_QDRANT_COLLECTION=insurevn_policy_chunks
RAG_DENSE_VECTOR_NAME=text_dense
RAG_SPARSE_VECTOR_NAME=text_sparse
RAG_EMBEDDING_PROVIDER=google_genai
RAG_EMBEDDING_MODEL=gemini-embedding-2
RAG_DENSE_VECTOR_SIZE=768
RAG_SPARSE_MODEL=Qdrant/bm25
RAG_VIETNAMESE_SEGMENTER=underthesea

# Chunking logic
RAG_CHUNKING_STRATEGY=hybrid_semantic
RAG_SEMANTIC_TARGET_CHARS=1400
RAG_SEMANTIC_MAX_CHARS=3500
RAG_SEMANTIC_MIN_CHARS=350
RAG_SEMANTIC_BREAKPOINT_TYPE=interquartile
RAG_SEMANTIC_BREAKPOINT_AMOUNT=1.5

# Knowledge Graph / Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
GRAPH_JSON_PATH=data/processed/knowledge_graph/insurevn_graph.json
GRAPH_MAX_HOPS=2

# Knowledge Graph Extraction/QA
# KG_EXTRACTION_LLM_PROVIDER=
# KG_EXTRACTION_LLM_MODEL=
KG_EXTRACTION_LLM_TEMPERATURE=0.0
# KG_CYPHER_QA_LLM_PROVIDER=
# KG_CYPHER_QA_LLM_MODEL=
KG_CYPHER_QA_LLM_TEMPERATURE=0.0

# Knowledge Graph Schema Discovery
# KG_SCHEMA_DISCOVERY_MAX_CONCURRENCY=20
# KG_SCHEMA_DISCOVERY_CHUNK_CHARS=12000
# KG_SCHEMA_DISCOVERY_OUTPUT_DIR=data/processed/knowledge_graph/schema_discovery

# Optional Tools
FIRECRAWL_API_KEY=
DATALAB_KEY=
